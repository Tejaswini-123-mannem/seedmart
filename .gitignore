# Root .gitignore — belt-and-suspenders on top of client/ and server/ ones.

# Dependencies (regenerated by npm install)
node_modules/
**/node_modules/

# Environment secrets — NEVER commit (real values live in host dashboards)
.env
**/.env
*.local

# Build output
dist/
**/dist/

# Logs
*.log
logs/

# OS / editor files
.DS_Store
.vscode/
.idea/
