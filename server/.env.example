# Copy this file to ".env" and fill in real values.
# This file (.env.example) is committed to git as documentation.
# The real .env file is gitignored and must NEVER be committed.

# ── Stage 1: Server + Database ──────────────────────────────
# Port Express listens on
PORT=5000

# MongoDB connection string
# Local development: mongodb://127.0.0.1:27017/seedmart
# Production (Atlas): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/seedmart
MONGO_URI=mongodb://127.0.0.1:27017/seedmart

# ── Stage 2: Authentication ─────────────────────────────────
# Secret key used to sign JWT tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# How long a token stays valid (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# First admin account, created by: node scripts/seedAdmin.js
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_PHONE=

# ── Stage 3b: Image uploads (Cloudinary) ────────────────────
# Found on your Cloudinary dashboard (cloudinary.com) after signing up.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stage 12: Deployment ────────────────────────────────────
# Allowed frontend origin(s) for CORS in production (no trailing slash).
# Leave BLANK in local dev to allow all origins.
# Example: https://seedmart.vercel.app
# Multiple allowed, comma-separated: https://seedmart.vercel.app,https://www.seedmart.com
CLIENT_URL=
